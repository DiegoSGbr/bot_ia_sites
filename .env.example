# Exemplo de configuração de ambiente (.env)

# Adicione aqui as variáveis de ambiente necessárias para o funcionamento do projeto.
# Exemplo:
# API_KEY=coloque_sua_chave_aqui
# DEBUG=True
# DATABASE_URL=sqlite:///app.db

# Renomeie este arquivo para .env e ajuste os valores conforme necessário.
# Copie este arquivo para `.env` e defina sua chave
# Não commite sua chave real em repositórios públicos.
GROQ_API_KEY=your_groq_api_key_here
# Opcional: altere se quiser testar outra URL/modelo
BASE_URL=https://dsmidias.rf.gd/index.html?i=1
# Padrão: modelo rápido. Para mais qualidade: llama-3.3-70b-versatile
MODEL=llama-3.1-8b-instant
# MAX_CONTEXT_CHARS=40000
# MAX_RESPONSE_TOKENS=1024
# MAX_HISTORY_MESSAGES=16
HF_TOKEN=your_huggingface_key_here